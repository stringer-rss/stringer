#!/usr/bin/env bash

set -euo pipefail

esbuild app/assets/stylesheets/application.css \
  --bundle \
  --outdir=app/assets/builds \
  --public-path=/assets \
  --asset-names=[name]-[hash].digested \
  --external:/img/* \
  --loader:.woff=file \
  --loader:.woff2=file \
  --loader:.eot=file \
  --loader:.ttf=file \
  --loader:.svg=file
